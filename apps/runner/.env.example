# Qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=triaige_triage_memory

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_DIMENSIONS=1536

# GitHub
GITHUB_TOKEN=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=triaige
LANGCHAIN_TRACING_V2=

# Database (local default; set to Neon connection string for production)
DATABASE_URL=postgresql://localhost:5432/triaige

# API key (shared secret — set the same value on dashboard as RUNNER_API_KEY)
API_KEY=

# API docs (set to true for local development; omit or false in production)
ENABLE_DOCS=true

# CORS — restrict to dashboard URL; comma-separated for multiple origins
CORS_ORIGINS=http://localhost:3000
