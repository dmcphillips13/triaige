# Runner service URL (FastAPI + LangGraph)
RUNNER_BASE_URL=http://localhost:8000

# Runner API key (shared secret — must match API_KEY on the runner)
RUNNER_API_KEY=

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Secret for signing session JWTs (generate with: openssl rand -hex 32)
AUTH_SECRET=

# Public app URL (for OAuth callback redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000
